-- Advanced Combat Script dengan GUI
-- Untuk tujuan edukasi saja

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local Workspace = game:GetService("Workspace")
local CoreGui = game:GetService("CoreGui")
local TweenService = game:GetService("TweenService")

local LocalPlayer = Players.LocalPlayer
local Character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
local HumanoidRootPart = Character:WaitForChild("HumanoidRootPart")

-- Konfigurasi
local Config = {
    RageMode = false,
    TeleportDistance = 3,
    PredictionAmount = 0.1,
    AimSmoothness = 0.3,
    MaxTargets = 5,
    CombatRadius = 50,
    AutoSwitchTarget = true,
    ShowTargetESP = true,
    SilentAim = true,
    TeleportBehind = true
}

-- Variabel sistem
local Targets = {}
local CurrentTarget = nil
local combatLoopConnection = nil
local ESPObjects = {}
local GUI = nil

-- Modul RAGE
local RageModule = {}

function RageModule:FindOptimalTarget()
    local closest = nil
    local shortestDistance = Config.CombatRadius
    
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local targetHRP = player.Character:FindFirstChild("HumanoidRootPart")
            if targetHRP then
                local distance = (HumanoidRootPart.Position - targetHRP.Position).Magnitude
                if distance < shortestDistance then
                    shortestDistance = distance
                    closest = player
                end
            end
        end
    end
    
    return closest
end

function RageModule:CalculateBehindPosition(targetHRP)
    if not targetHRP then return HumanoidRootPart.Position end
    
    local lookVector = targetHRP.CFrame.LookVector
    local behindOffset = lookVector * -Config.TeleportDistance
    behindOffset = behindOffset + Vector3.new(0, 2, 0)
    
    return targetHRP.Position + behindOffset
end

function RageModule:SafeTeleport(position)
    if not Config.TeleportBehind then return false end
    
    local ray = Ray.new(position + Vector3.new(0, 10, 0), Vector3.new(0, -20, 0))
    local hit, hitPos = Workspace:FindPartOnRay(ray, Character)
    
    if hit then
        HumanoidRootPart.CFrame = CFrame.new(Vector3.new(position.X, hitPos.Y + 3, position.Z))
        return true
    end
    return false
end

function RageModule:CalculateSilentAim(targetHRP)
    if not Config.SilentAim then 
        return (targetHRP.Position - HumanoidRootPart.Position).Unit 
    end
    
    if not targetHRP then return HumanoidRootPart.CFrame.LookVector end
    
    local velocity = targetHRP.Velocity or Vector3.new(0, 0, 0)
    local predictedPosition = targetHRP.Position + (velocity * Config.PredictionAmount)
    
    local direction = (predictedPosition - HumanoidRootPart.Position).Unit
    return direction
end

function RageModule:SimulateAttack(target)
    if not target or not target.Character then return end
    
    -- Simulasi serangan (log saja untuk sekarang)
    if GUI and GUI.TargetLabel then
        GUI.TargetLabel.Text = "Target: " .. target.Name
    end
end

function RageModule:StartCombatLoop()
    if combatLoopConnection then
        combatLoopConnection:Disconnect()
    end
    
    combatLoopConnection = RunService.Heartbeat:Connect(function(deltaTime)
        if not Config.RageMode then 
            if CurrentTarget and GUI.TargetLabel then
                GUI.TargetLabel.Text = "Target: None"
            end
            return 
        end
        
        if not Character or not HumanoidRootPart then return end
        
        -- Cari target baru jika perlu
        if not CurrentTarget or (Config.AutoSwitchTarget and CurrentTarget) then
            CurrentTarget = RageModule:FindOptimalTarget()
            if not CurrentTarget then 
                if GUI.TargetLabel then
                    GUI.TargetLabel.Text = "Target: None"
                end
                return 
            end
        end
        
        -- Verifikasi target
        if not CurrentTarget.Character or not CurrentTarget.Character:FindFirstChild("HumanoidRootPart") then
            CurrentTarget = nil
            return
        end
        
        local targetHRP = CurrentTarget.Character.HumanoidRootPart
        
        -- Teleport ke belakang target
        if Config.TeleportBehind then
            local behindPos = RageModule:CalculateBehindPosition(targetHRP)
            RageModule:SafeTeleport(behindPos)
        end
        
        -- Hitung aim
        RageModule:CalculateSilentAim(targetHRP)
        
        -- Serang target
        RageModule:SimulateAttack(CurrentTarget)
        
        -- Cek jika perlu ganti target
        local distance = (HumanoidRootPart.Position - targetHRP.Position).Magnitude
        if distance > Config.CombatRadius then
            CurrentTarget = nil
        end
    end)
end

function RageModule:StopCombatLoop()
    if combatLoopConnection then
        combatLoopConnection:Disconnect()
        combatLoopConnection = nil
    end
    CurrentTarget = nil
end

-- Fungsi ESP (Highlight target)
function CreateESP(target)
    if not Config.ShowTargetESP then return end
    
    if target.Character then
        local highlight = Instance.new("Highlight")
        highlight.Name = "TargetESP_" .. target.Name
        highlight.Parent = target.Character
        highlight.FillColor = Color3.fromRGB(255, 0, 0)
        highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
        highlight.FillTransparency = 0.5
        highlight.OutlineTransparency = 0
        
        ESPObjects[target.Name] = highlight
    end
end

function RemoveESP(targetName)
    if ESPObjects[targetName] then
        ESPObjects[targetName]:Destroy()
        ESPObjects[targetName] = nil
    end
end

