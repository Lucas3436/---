local function removeESP(plr)
    if espObjects[plr] then
        for _,v in pairs(espObjects[plr]) do
            if v and v.Parent then v:Destroy() end
        end
        espObjects[plr] = nil
    end
end

local function createESP(plr)
    if not plr.Character then return end
    local head = plr.Character:FindFirstChild("Head")
    if not head then return end

    removeESP(plr)

    local gui = Instance.new("BillboardGui")
    gui.Name = "ESP"
    gui.Adornee = head
    gui.Size = UDim2.new(0,120,0,40)
    gui.StudsOffset = Vector3.new(0, 1.5, 0)
    gui.AlwaysOnTop = true
    gui.Parent = head

    local box = Instance.new("Frame")
    box.Name = "Box"
    box.Size = UDim2.new(1,0,1,0)
    box.BackgroundTransparency = 1
    box.BorderSizePixel = 2
    box.BorderColor3 = isWhitelisted(plr) and Color3.fromRGB(255,255,0) or Color3.fromRGB(255,0,0)
    box.Parent = gui

    local nameLabel = Instance.new("TextLabel")
    nameLabel.Name = "Name"
    nameLabel.Size = UDim2.new(1,0,0,16)
    nameLabel.Position = UDim2.new(0,0,0,-18)
    nameLabel.BackgroundTransparency = 1
    local displayName = (plr.DisplayName and #plr.DisplayName>0) and plr.DisplayName or plr.Name
    nameLabel.Text = displayName
    nameLabel.TextColor3 = Color3.fromRGB(255,255,255)
    nameLabel.TextStrokeTransparency = 0.4
    nameLabel.TextScaled = true
    nameLabel.Font = Enum.Font.GothamBold
    nameLabel.Parent = gui

    espObjects[plr] = {gui = gui, box = box, label = nameLabel}
end

