local function createSlider(parent,labelText,minValue,maxValue,defaultValue,y,onChange)
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1,0,0,20)
    label.Position = UDim2.new(0,0,0,y)
    label.BackgroundColor3 = Color3.fromRGB(0,0,0)
    label.BackgroundTransparency = 0.2
    label.Text = labelText..": "..tostring(defaultValue)
    label.TextColor3 = Color3.fromRGB(255,255,255)
    label.Font = Enum.Font.Gotham
    label.TextSize = 13
    label.Parent = parent
    Instance.new("UICorner", label).CornerRadius = UDim.new(0,8)

    local bar = Instance.new("Frame")
    bar.Size = UDim2.new(1,0,0,10)
    bar.Position = UDim2.new(0,0,0,y+24)
    bar.BackgroundColor3 = Color3.fromRGB(0,0,0)
    bar.BackgroundTransparency = 0.5
    bar.Parent = parent
    Instance.new("UICorner", bar).CornerRadius = UDim.new(0,8)

    local fill = Instance.new("Frame")
    fill.Size = UDim2.new(0,0,1,0)
    fill.BackgroundColor3 = Color3.fromRGB(0,0,0)
    fill.BackgroundTransparency = 0.1
    fill.Parent = bar
    Instance.new("UICorner", fill).CornerRadius = UDim.new(0,8)

    local knob = Instance.new("Frame")
    knob.Size = UDim2.new(0,12,0,18)
    knob.Position = UDim2.new(0,0,0.5,-9)
    knob.BackgroundColor3 = Color3.fromRGB(0,0,0)
    knob.BackgroundTransparency = 0
    knob.Parent = bar
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1,0)

    local dragging = false
    local value = defaultValue

    local function setVisualFromValue(v)
        local alpha = (v - minValue)/(maxValue-minValue)
        alpha = math.clamp(alpha,0,1)
        fill.Size = UDim2.new(alpha,0,1,0)
        knob.Position = UDim2.new(alpha,-6,0.5,-9)
        label.Text = labelText..": "..math.floor(v+0.5)
    end

    local function setValue(v)
        value = math.clamp(v,minValue,maxValue)
        setVisualFromValue(value)
        if onChange then onChange(value) end
    end

    local function valueFromX(x)
        local startX = bar.AbsolutePosition.X
        local width = bar.AbsoluteSize.X
        local alpha = math.clamp((x-startX)/math.max(1,width),0,1)
        return minValue + alpha*(maxValue-minValue)
    end

    bar.InputBegan:Connect(function(input)
        if input.UserInputType==Enum.UserInputType.MouseButton1 then
            dragging=true
            setValue(valueFromX(input.Position.X))
        end
    end)

    knob.InputBegan:Connect(function(input)
        if input.UserInputType==Enum.UserInputType.MouseButton1 then dragging=true end
    end)

    UIS.InputEnded:Connect(function(input)
        if input.UserInputType==Enum.UserInputType.MouseButton1 then dragging=false end
    end)

    UIS.InputChanged:Connect(function(input)
        if dragging and input.UserInputType==Enum.UserInputType.MouseMovement then
            setValue(valueFromX(input.Position.X))
        end
    end)

    setValue(defaultValue)
    return {Get=function() return value end, Set=setValue, Label=label}
end

