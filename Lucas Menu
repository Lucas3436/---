    if espEnabled then
        for _,plr in pairs(Players:GetPlayers()) do
            if plr ~= LocalPlayer then
                if plr.Character and plr.Character:FindFirstChild("Head") then
                    if not espObjects[plr] then
                        createESP(plr)
                    else
                        local ok, obj = pcall(function() return espObjects[plr] end)
                        if ok and obj and obj.box and obj.label then
                            obj.box.BorderColor3 = isWhitelisted(plr) and Color3.fromRGB(255,255,0) or Color3.fromRGB(255,0,0)
