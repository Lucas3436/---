-- Force teleport function
local function forceTeleport()
    if savedPosition and hrp then
        local targetCFrame = CFrame.new(savedPosition)
        local originalCanCollide = hrp.CanCollide
        hrp.CanCollide = false -- Disable collisions to avoid physics blocking

        -- Force teleport every frame
        local connection
        connection = RunService.Heartbeat:Connect(function()
            if (hrp.Position - savedPosition).Magnitude > 0.1 then
                hrp.CFrame = targetCFrame
            else
                hrp.CanCollide = originalCanCollide
                connection:Disconnect()
            end
        end)
    end
end

tpBtn.MouseButton1Click:Connect(forceTeleport)

